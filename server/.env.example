PORT=3001
# For local development, use: mongodb://localhost:27017/derive-ai
# For MongoDB Atlas, get your connection string from the MongoDB Atlas dashboard
# Go to: Clusters → Connect → Connect your application → Copy connection string
# Replace <username>, <password>, and <cluster-url> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/derive-ai?retryWrites=true&w=majority&appName=DeriveAI
NODE_ENV=development
OPENROUTER_API_KEY=your-openrouter-api-key-here
YOUR_SITE_URL=http://localhost:3001